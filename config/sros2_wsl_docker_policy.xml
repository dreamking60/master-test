<?xml version="1.0" encoding="UTF-8"?>
<policy version="0.2.0">
  <enclaves>
    <enclave path="/controller">
      <profiles>
        <profile ns="/" node="controller">
          <topics publish="ALLOW">
            <topic>/cmd_vel_in</topic>
            <topic>/rosout</topic>
            <topic>/parameter_events</topic>
          </topics>
          <topics subscribe="ALLOW">
            <topic>/parameter_events</topic>
          </topics>
          <services reply="ALLOW">
            <service>/*</service>
          </services>
          <services request="ALLOW">
            <service>/*</service>
          </services>
        </profile>
      </profiles>
    </enclave>

    <enclave path="/attacker">
      <profiles>
        <profile ns="/" node="attacker">
          <topics publish="ALLOW">
            <topic>/rosout</topic>
            <topic>/parameter_events</topic>
          </topics>
          <topics subscribe="ALLOW">
            <topic>/parameter_events</topic>
          </topics>
          <services reply="ALLOW">
            <service>/*</service>
          </services>
          <services request="ALLOW">
            <service>/*</service>
          </services>
        </profile>
      </profiles>
    </enclave>

    <enclave path="/gazebo">
      <profiles>
        <profile ns="/" node="cmd_vel_relay">
          <topics publish="ALLOW">
            <topic>/cmd_vel</topic>
            <topic>/rosout</topic>
            <topic>/parameter_events</topic>
          </topics>
          <topics subscribe="ALLOW">
            <topic>/cmd_vel_in</topic>
            <topic>/parameter_events</topic>
          </topics>
          <services reply="ALLOW">
            <service>/*</service>
          </services>
          <services request="ALLOW">
            <service>/*</service>
          </services>
        </profile>

        <profile ns="/" node="trajectory_trail_spawner">
          <topics publish="ALLOW">
            <topic>/rosout</topic>
            <topic>/parameter_events</topic>
          </topics>
          <topics subscribe="ALLOW">
            <topic>/odom</topic>
            <topic>/parameter_events</topic>
          </topics>
          <services reply="ALLOW">
            <service>/*</service>
          </services>
          <services request="ALLOW">
            <service>/*</service>
          </services>
        </profile>

        <profile ns="/" node="ros_gz_bridge">
          <topics publish="ALLOW" subscribe="ALLOW">
            <topic>/*</topic>
          </topics>
          <services reply="ALLOW" request="ALLOW">
            <service>/*</service>
          </services>
          <actions call="ALLOW" execute="ALLOW">
            <action>/*</action>
          </actions>
        </profile>

        <profile ns="/" node="robot_state_publisher">
          <topics publish="ALLOW" subscribe="ALLOW">
            <topic>/*</topic>
          </topics>
          <services reply="ALLOW" request="ALLOW">
            <service>/*</service>
          </services>
          <actions call="ALLOW" execute="ALLOW">
            <action>/*</action>
          </actions>
        </profile>

        <profile ns="/" node="create">
          <topics publish="ALLOW" subscribe="ALLOW">
            <topic>/*</topic>
          </topics>
          <services reply="ALLOW" request="ALLOW">
            <service>/*</service>
          </services>
          <actions call="ALLOW" execute="ALLOW">
            <action>/*</action>
          </actions>
        </profile>
      </profiles>
    </enclave>
  </enclaves>
</policy>
